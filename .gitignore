# dependencies
/node_modules
/.pnp
.pnp.js
.yarn/install-state.gz

# testing
/coverage

# next.js
/.next/
/.next-*/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# local env files
.env*.local

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# playwright test artifacts
/test-results/
/playwright-report/

# internal Teams meeting recordings + working artifacts (raw video/audio/frames/
# transcripts of Freyr internal calls — not app code, keep off GitHub)
teams-video*/
TEAMS-VIDEO*-REVIEW.md

# Internal design references (Kendo AI teardown screenshots — ~15MB, keep out of the public repo; ANALYSIS.md is fine to keep local)
references/kendo-ai/*.png

# internal working artifacts — build-loop notes, audits, feedback reviews and
# local diag/tooling scripts. Not app code; keep off GitHub.
AUDIT-*.md
AGENT-CHAT-SCENARIOS.md
AGENT-TEST-REPORT.md
AGENT-VISION.md
SUREN-VIDEO-REVIEW.md
references/
scripts/
