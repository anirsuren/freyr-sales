# Workspace behavior
DEFAULT_DATA_MODE=mock
DATA_MODE_LOCKED=0
AUTH_MODE=
# Set to approval only after SSO, the migration, Supabase, and a 32+ character
# cookie secret are configured. Leaving it blank keeps local/Vercel demos open.
ACCESS_CONTROL_MODE=
AUTH_COOKIE_SECRET=
OWNER_EMAILS=
FREYR_WORKSPACE_ID=
FREYR_WORKSPACE_NAME=Freyr Sales

# AI and enrichment providers (used only when clean/live mode is active)
ANTHROPIC_API_KEY=
FIRECRAWL_API_KEY=
APIFY_API_TOKEN=

# Durable PostgreSQL/Supabase adapter
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Optional delivery channels
RESEND_API_KEY=
EMAIL_FROM=
HUBSPOT_ACCESS_TOKEN=
SALESFORCE_CLIENT_ID=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
ELEVENLABS_API_KEY=
ELEVENLABS_PHONE_NUMBER_ID=
ELEVENLABS_WEBHOOK_SECRET=
# Set this as an x-freyr-voice-secret custom header on the ElevenLabs inbound
# personalization webhook. It is separate from post-call HMAC verification.
ELEVENLABS_INBOUND_WEBHOOK_SECRET=
FREYR_VOICE_NUMBER=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_NUMBER=
